# ----------------------------
# Python / Backend
# ----------------------------

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment (if using Poetry's in-project .venv)
.venv/
env/
venv/

# Poetry lock files (optional to ignore, usually you commit poetry.lock)
# poetry.lock

# IDE / Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# ----------------------------
# Node / Frontend (React + Vite)
# ----------------------------

# Node modules
frontend/node_modules/

# Build / dist folders
frontend/dist/
frontend/build/

# Env files
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ----------------------------
# Misc
# ----------------------------
*.pyc
*.pyo
*.pyd
*.swp